# .env.example
# Set your environment variables in .env similar to this example file.

# To determine latitude/longitude, access the NWS website and search for your city.
# Example: https://forecast.weather.gov/MapClick.php?lat=39.1031&lon=-84.5120
latitude = 00.0000
longitude = -00.0000

# Set your city name. This will be used in the Teams message title.
city = "Cityville"

# Set your NWS office city and state. This is used in citing the forecast source.
nws_office_city = "Capitalcity"
nws_office_state = "State"

# Set your Microsoft Teams webhook URLs to send messages to your Teams channels.
forecast_teams_webhook = "YOUR_WEBHOOK_URL_HERE"
alerts_teams_webhook = "YOUR_WEBHOOK_URL_HERE"

# Set the NWS county zones to monitor for alerts.
# Find your county codes at https://api.weather.gov/zones/county/ or by checking a location on weather.gov
# The county codes are in the format: state code + C + county FIPS code (e.g., OHC061 for Hamilton County, OH)
# Format: code:CountyName,code:CountyName,... (no spaces after colons or commas)
county_zones = "OHC061:Hamilton,OHC025:Clermont,OHC165:Warren"